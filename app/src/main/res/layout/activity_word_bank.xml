<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:importantForAccessibility="noHideDescendants"
    android:fitsSystemWindows="true"
    android:background="#FAFAFA">

    <!-- 標題列：標題 + AI講解 + 儲存 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp"
        android:gravity="center_vertical"
        android:background="#FFFFFF"
        android:elevation="2dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="📖 單字庫管理"
            android:textSize="18sp"
            android:textColor="#212121"
            android:textStyle="bold"/>

        <Button
            android:id="@+id/btnAiExplain"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="🤖 AI講解"
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#1565C0"
            android:layout_marginEnd="6dp"/>

        <Button
            android:id="@+id/btnSaveWordBank"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="儲存"
            android:textSize="14sp"/>
    </LinearLayout>

    <!-- 詞庫選擇列 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical"
        android:background="#F5F5F5">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="詞庫："
            android:textColor="#424242"
            android:textSize="14sp"
            android:layout_marginEnd="8dp"/>

        <Spinner
            android:id="@+id/spinnerWordType"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"/>
    </LinearLayout>

    <!-- 即時搜尋列（所有 tab 都顯示）-->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:gravity="center_vertical"
        android:background="#FFFFFF">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔍"
            android:textSize="16sp"
            android:layout_marginEnd="8dp"/>

        <EditText
            android:id="@+id/etSearch"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:hint="輸入字母即時篩選單字..."
            android:inputType="text"
            android:importantForAutofill="no"
            android:maxLines="1"
            android:imeOptions="actionDone"
            android:background="@android:drawable/editbox_background"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"/>
    </LinearLayout>

    <!-- 新增單字列（一般詞庫時顯示）-->
    <LinearLayout
        android:id="@+id/layoutAddWord"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <EditText
            android:id="@+id/etNewWord"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:layout_weight="1"
            android:hint="輸入新單字"
            android:importantForAutofill="no"
            android:inputType="textNoSuggestions"
            android:layout_marginEnd="8dp"/>

        <Button
            android:id="@+id/btnAddWord"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="新增"/>
    </LinearLayout>

    <!-- 統計文字 -->
    <TextView
        android:id="@+id/tvWordCount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingBottom="6dp"
        android:textSize="12sp"
        android:textColor="#9E9E9E"/>

    <!-- 單字列表：改用 RecyclerView 實現虛擬化渲染 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerWordList"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        android:paddingBottom="@dimen/bottom_safe_padding"
        android:clipToPadding="false"
        android:fadeScrollbars="false"/>

</LinearLayout>
