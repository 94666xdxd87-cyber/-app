<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    android:background="#FAFAFA">

    <!-- 標題列 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:background="#FFFFFF"
        android:elevation="3dp">

        <ImageButton
            android:id="@+id/btnQuestionDetailBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_media_previous"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="返回"/>

        <TextView
            android:id="@+id/tvQuestionDetailTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="題目詳細"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#212121"
            android:paddingStart="8dp"
            android:maxLines="1"
            android:ellipsize="end"/>
    </LinearLayout>

    <!-- 題目資訊標籤列 -->
    <LinearLayout
        android:id="@+id/layoutQuestionMeta"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="10dp"
        android:gravity="center_vertical"
        android:background="#E3F2FD">

        <TextView
            android:id="@+id/tvQuestionMetaExamType"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="#FFFFFF"
            android:background="#1565C0"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:layout_marginEnd="6dp"/>

        <TextView
            android:id="@+id/tvQuestionMetaYear"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="#FFFFFF"
            android:background="#0277BD"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:layout_marginEnd="6dp"/>

        <TextView
            android:id="@+id/tvQuestionMetaSubject"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="12sp"
            android:textColor="#1565C0"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvQuestionMetaScore"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="#E65100"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- 完整題目內容（可滑動） -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 題目標頭 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📌 題目內容"
                android:textSize="13sp"
                android:textColor="#616161"
                android:textStyle="bold"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="14dp"
                android:paddingBottom="6dp"/>

            <!-- 題目本文 -->
            <TextView
                android:id="@+id/tvQuestionFullText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:textColor="#212121"
                android:lineSpacingMultiplier="1.6"
                android:padding="16dp"
                android:background="#FFFFFF"
                android:textIsSelectable="true"/>

            <!-- 作答次數 -->
            <TextView
                android:id="@+id/tvQuestionAnsweredCount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="#2E7D32"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="10dp"
                android:paddingBottom="4dp"
                android:visibility="gone"/>

        </LinearLayout>
    </ScrollView>

    <!-- 底部操作列 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:elevation="6dp"
        android:padding="12dp">

        <Button
            android:id="@+id/btnViewAnswerRecords"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="📋 查看作答紀錄"
            android:textSize="15sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#2E7D32"
            android:layout_marginBottom="8dp"
            android:visibility="gone"/>

        <Button
            android:id="@+id/btnStartAnswer"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="✏️ 開始作答"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#1565C0"/>

    </LinearLayout>

</LinearLayout>
