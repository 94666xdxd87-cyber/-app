<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="#FAFAFA"
    android:clipToPadding="false"
    android:paddingBottom="@dimen/bottom_safe_padding">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📚 英文單字練習"
            android:textSize="24sp"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingTop="12dp"
            android:paddingBottom="4dp"/>

        <TextView
            android:id="@+id/tvPoolStats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="載入單字庫中..."
            android:textSize="12sp"
            android:gravity="center"
            android:paddingBottom="12dp"/>

        <Button
            android:id="@+id/btnApiKey"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="🔑 設定 API Key ⚠️"
            android:textColor="#E53935"
            android:layout_marginBottom="6dp"/>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="── 練習模式 ──" android:gravity="center"
            android:textSize="12sp" android:textColor="#9E9E9E" android:layout_marginBottom="6dp"/>

        <Button android:id="@+id/btn1" style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent" android:layout_height="48dp"
            android:text="📘 名詞單獨練習" android:layout_marginBottom="6dp"/>
        <Button android:id="@+id/btn2" style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent" android:layout_height="48dp"
            android:text="📗 副詞單獨練習" android:layout_marginBottom="6dp"/>
        <Button android:id="@+id/btn3" style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent" android:layout_height="48dp"
            android:text="📙 形容詞單獨練習" android:layout_marginBottom="6dp"/>
        <Button android:id="@+id/btn4" style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent" android:layout_height="48dp"
            android:text="🎬 動詞單獨練習" android:layout_marginBottom="6dp"/>

        <!-- btn5 (全隨機混合) 已移除 -->

        <Button android:id="@+id/btn6" style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent" android:layout_height="48dp"
            android:text="🎯 自訂比例混合模式" android:layout_marginBottom="6dp"/>

        <Button android:id="@+id/btn7"
            android:layout_width="match_parent" android:layout_height="48dp"
            android:text="🚨 弱點搶救模式"
            android:backgroundTint="#E53935" android:textColor="#FFFFFF"
            android:layout_marginBottom="14dp"/>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="── 連線挑戰 ──" android:gravity="center"
            android:textSize="12sp" android:textColor="#9E9E9E" android:layout_marginBottom="6dp"/>

        <Button android:id="@+id/btnOnlineExam"
            android:layout_width="match_parent" android:layout_height="56dp"
            android:text="🏆 全國線上模擬考"
            android:textSize="18sp"
            android:textStyle="bold"
            android:backgroundTint="#FFB300"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="14dp"/>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="── 工具 ──" android:gravity="center"
            android:textSize="12sp" android:textColor="#9E9E9E" android:layout_marginBottom="6dp"/>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button android:id="@+id/btnWordBank"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp" android:layout_height="48dp"
                android:layout_weight="1" android:text="📖 單字庫"
                android:padding="0dp"
                android:layout_marginEnd="4dp"/>

            <Button android:id="@+id/btnWordExplain"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp" android:layout_height="48dp"
                android:layout_weight="1.2" android:text="🤖 AI 歷史"
                android:textColor="#1976D2"
                android:padding="0dp"
                android:layout_marginEnd="4dp"/>

            <Button android:id="@+id/btnHistory"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp" android:layout_height="48dp"
                android:layout_weight="1" android:text="📊 成績"
                android:padding="0dp"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
