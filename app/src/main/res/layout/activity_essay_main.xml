<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    android:background="#FAFAFA">

    <!-- 標題列 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:background="#FFFFFF"
        android:elevation="3dp">

        <ImageButton
            android:id="@+id/btnEssayMainBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_media_previous"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="返回"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="✏️ 申論題練習"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#212121"
            android:paddingStart="8dp"/>

        <Button
            android:id="@+id/btnEssayAdd"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="＋ 新增"
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#1565C0"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"/>
    </LinearLayout>

    <!-- 功能列：考古題 + 重點整理 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="10dp"
        android:background="#E8F5E9">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:text="📄 歷屆考古題庫"
            android:textSize="14sp"
            android:textColor="#2E7D32"
            android:textStyle="bold"/>

        <Button
            android:id="@+id/btnKeyPoints"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="📌 重點整理"
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#6A1B9A"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:layout_marginEnd="8dp"/>

        <Button
            android:id="@+id/btnPastExam"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="查看 / 練習"
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#2E7D32"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"/>
    </LinearLayout>

    <!-- 分隔線 -->
    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="#E0E0E0"/>

    <!-- 空狀態提示 -->
    <TextView
        android:id="@+id/tvEssayEmpty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="尚無申論題紀錄\n點擊右上角「＋ 新增」開始"
        android:textSize="16sp"
        android:textColor="#9E9E9E"
        android:visibility="gone"/>

    <!-- 紀錄列表 -->
    <ListView
        android:id="@+id/essayListView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="#E0E0E0"
        android:dividerHeight="1dp"
        android:paddingBottom="@dimen/bottom_safe_padding"
        android:clipToPadding="false"/>

</LinearLayout>
