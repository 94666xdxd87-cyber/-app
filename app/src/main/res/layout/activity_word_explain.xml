<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    android:background="#FAFAFA">

    <!-- 標題列 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp"
        android:gravity="center_vertical"
        android:background="#FFFFFF"
        android:elevation="2dp">

        <TextView
            android:id="@+id/tvExplainStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="AI 單字講解"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#212121"/>

        <ProgressBar
            android:id="@+id/pbExplain"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginEnd="8dp"
            android:visibility="gone"/>

    </LinearLayout>

    <!-- 一鍵下載音檔按鈕列（僅歷史模式顯示）-->
    <LinearLayout
        android:id="@+id/layoutDownloadBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="10dp"
        android:gravity="center_vertical"
        android:background="#E8F5E9"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvDownloadStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="📥 可一鍵下載所有單字發音"
            android:textSize="13sp"
            android:textColor="#2E7D32"/>

        <Button
            android:id="@+id/btnDownloadAll"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="🔊 下載音檔"
            android:textSize="12sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#43A047"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"/>

    </LinearLayout>

    <!-- 即時搜尋列（僅歷史模式顯示）-->
    <LinearLayout
        android:id="@+id/layoutSearchBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:gravity="center_vertical"
        android:background="#FFFFFF"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔍"
            android:textSize="16sp"
            android:layout_marginEnd="8dp"/>

        <EditText
            android:id="@+id/etSearch"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:hint="輸入字母即時篩選單字..."
            android:inputType="text"
            android:importantForAutofill="no"
            android:maxLines="1"
            android:imeOptions="actionDone"
            android:background="@android:drawable/editbox_background"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"/>

    </LinearLayout>

    <!-- 講解列表 -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="10dp">

        <LinearLayout
            android:id="@+id/layoutExplainList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"/>

    </ScrollView>

    <!-- 返回按鈕 -->
    <Button
        android:id="@+id/btnBackFromExplain"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="返回"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="@dimen/bottom_safe_padding"/>

</LinearLayout>
